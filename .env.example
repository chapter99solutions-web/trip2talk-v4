# From Supabase Dashboard → Project Settings → API (trip2talk-v4, ap-southeast-2)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# anon / publishable key (sb_publishable_... or legacy eyJ... JWT)
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# Note: .env.local overrides .env — keep both in sync or remove duplicate keys from .env.local
# Setup: see supabase/README.md (schemas, functions, secrets)

# Google Apps Script Web App — READ-ONLY in browser (trips/bookings GET).
# POST/sync writes go through Supabase Edge Function `sync-pipeline` (secret GAS_WEBAPP_URL).
# Must match deployed Apps Script web app (/exec). Set SPREADSHEET_ID in Script properties — see docs/GAS_TRIPS_DATA.md
VITE_GAS_WEBAPP_URL=https://script.google.com/macros/s/XXXXXXXXXXXX/exec

# Vercel serverless /api/create-booking (same GAS URL, not exposed to browser POST)
GAS_WEBAPP_URL=https://script.google.com/macros/s/XXXXXXXXXXXX/exec
# Public site origin for portal links in API responses (Vercel serverless)
SITE_URL=https://www.trip2talk.com.au
NEXT_PUBLIC_SITE_URL=https://www.trip2talk.com.au
# Client bundle (Vite) — same origin for CMS copy-link helpers
VITE_PUBLIC_SITE_URL=https://www.trip2talk.com.au
