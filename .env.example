# From Supabase Dashboard → Project Settings → API (trip2talk-v4, ap-southeast-2)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# anon / publishable key (sb_publishable_... or legacy eyJ... JWT)
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# Note: .env.local overrides .env — keep both in sync or remove duplicate keys from .env.local
